# ============================================================================
# Glass — Backend · Variables de entorno (ADR-009)
# Copia este archivo a `.env` y completa los valores. NUNCA commitees `.env`.
# ============================================================================

# --- App ---
APP_NAME=Glass API
ENVIRONMENT=development          # development | staging | production
DEBUG=true

# --- CORS (frontend Next.js) ---
FRONTEND_URL=http://localhost:3000,https://pucp-reto.vercel.app

# --- Base de datos (PostgreSQL + PostGIS, ADR-006) ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/glass

# --- Caché (Redis, ADR-007) ---
REDIS_URL=redis://localhost:6379/0

# --- Gemini API (extracción de partidas, ADR-001) ---
GEMINI_API_KEY=

# --- Firecrawl (descarga de PDFs desde INFOBRAS) ---
FIRECRAWL_API_KEY=

# --- Fuentes externas (ADR-002) ---
SEACE_OCDS_BASE_URL=https://contratacionesabiertas.oece.gob.pe
INFOBRAS_BASE_URL=https://appbp.contraloria.gob.pe/BuscadorCGR/Infobras

# --- Autenticación (RNF-08) ---
JWT_SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
